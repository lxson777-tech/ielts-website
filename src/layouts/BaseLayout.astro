---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import VocabQuizInit from '../components/VocabQuizInit.astro';
import { withBase } from '../lib/url';

interface Props {
  title: string;
  description?: string;
  /** Hide nav/footer chrome (used by the fullscreen test player). */
  bare?: boolean;
  /** Root-relative image path (e.g. '/pics/hero.png'), passed through withBase(). */
  ogImage?: string;
  /** Defaults to 'website'; blog posts should pass 'article'. */
  ogType?: string;
}

const {
  title,
  description = 'Free IELTS preparation: lessons, strategies and timed practice tests for every skill.',
  bare = false,
  ogImage = '/pics/hero.png',
  ogType = 'website',
} = Astro.props;

const canonicalUrl = new URL(withBase(Astro.url.pathname), Astro.site).toString();
const absoluteOgImage = new URL(withBase(ogImage), Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'IELTS Website',
  description: 'Free IELTS preparation: lessons, strategies and timed practice tests for every skill.',
  url: new URL(withBase('/'), Astro.site).toString(),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <ClientRouter />
  </head>
  <body class="flex min-h-screen flex-col bg-surface text-ink">
    {!bare && <Nav />}
    <main class="flex-1" transition:animate="fade">
      <slot />
    </main>
    {!bare && <Footer />}
    {!bare && <VocabQuizInit />}
    <script>
      const REVEAL_SELECTOR = [
        '[data-reveal]',
        '.lesson-body .section',
        '.lesson-body .vocab-table',
        '.lesson-body .exercise-box',
        '.lesson-body .type-example',
        '.lesson-body .cue-card',
        '.lesson-body .criteria-card',
        '.lesson-body .answer-compare',
        '.lesson-body .passage-box',
        '.lesson-body .task-type-card',
        '.lesson-body .cta-card',
      ].join(',');

      function initScrollReveal() {
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        // Anything nested inside a <details> (worked examples, "show model
        // report", …) starts hidden until the user opens it, so it never
        // has a chance to naturally intersect while closed — and once
        // opened it should just be there, not queue its own separate
        // fade-up on top of the accordion's own open animation.
        const els = Array.from(document.querySelectorAll<HTMLElement>(REVEAL_SELECTOR)).filter(
          (el) => !el.closest('details'),
        );

        els.forEach((el, i) => {
          if (el.classList.contains('reveal-init')) return;
          el.classList.add('reveal-init');
          el.style.setProperty('--reveal-delay', `${(i % 6) * 70}ms`);
        });

        if (reduceMotion || !('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }

        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          // threshold 0 (any visible pixel), not a ratio: tall sections on
          // narrow phone screens may never have 12% on screen at once, and a
          // fast fling can skip past a ratio threshold entirely, leaving
          // content permanently invisible.
          { threshold: 0, rootMargin: '0px 0px -8% 0px' },
        );
        els.forEach((el) => {
          if (!el.classList.contains('is-visible')) io.observe(el);
        });
      }

      // Safety net for the observer above: fast flings can skip an element
      // between rendered frames, anchor jumps teleport past whole sections,
      // and island hydration can swap a node out from under the observer,
      // all of which leave content permanently invisible. On scroll,
      // force-reveal anything the user has already reached or passed,
      // querying the live DOM so replaced nodes are covered too.
      let sweepQueued = false;
      function revealReached() {
        sweepQueued = false;
        for (const el of document.querySelectorAll<HTMLElement>('.reveal-init:not(.is-visible)')) {
          if (el.closest('details')) continue;
          if (el.getBoundingClientRect().top < window.innerHeight * 0.95) el.classList.add('is-visible');
        }
      }
      function queueRevealSweep() {
        if (sweepQueued) return;
        sweepQueued = true;
        requestAnimationFrame(revealReached);
      }
      document.addEventListener('scroll', queueRevealSweep, { passive: true, capture: true });

      initScrollReveal();
      // Late sweep: catch nodes hydration replaced inside the initial viewport.
      setTimeout(revealReached, 1500);
      document.addEventListener('astro:page-load', () => {
        initScrollReveal();
        setTimeout(revealReached, 1500);
      });

      // Animated <details>/<summary> expand-collapse — covers every
      // collapsible in lesson content (worked examples, "show model
      // report", quiz answers, …) so opening one smoothly grows instead
      // of the browser's instant snap. Wraps whatever markup follows
      // <summary> in a single measurable element at runtime so it works
      // regardless of how the migrated content nests its children.
      function initDetailsAnimation() {
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const allDetails = document.querySelectorAll<HTMLDetailsElement>(
          '.lesson-body details:not([data-animated])',
        );

        allDetails.forEach((details) => {
          details.dataset.animated = 'true';
          const summary = details.querySelector(':scope > summary');
          if (!summary) return;

          if (reduceMotion) return; // native open/close is already instant

          const content = document.createElement('div');
          content.className = 'details-content';
          let node = summary.nextSibling;
          while (node) {
            const next = node.nextSibling;
            content.appendChild(node);
            node = next;
          }
          details.appendChild(content);

          let animation: Animation | null = null;

          summary.addEventListener('click', (e) => {
            e.preventDefault();
            if (details.classList.contains('is-animating')) return;
            details.open ? collapse() : expand();
          });

          function expand() {
            details.classList.add('is-animating', 'is-open');
            details.open = true;
            const endHeight = content.offsetHeight;
            animation?.cancel();
            content.style.height = '0px';
            animation = content.animate(
              [{ height: '0px' }, { height: `${endHeight}px` }],
              { duration: 250, easing: 'cubic-bezier(.16,1,.3,1)' },
            );
            animation.onfinish = () => {
              content.style.height = 'auto';
              details.classList.remove('is-animating');
            };
          }

          function collapse() {
            details.classList.add('is-animating');
            details.classList.remove('is-open');
            const startHeight = content.offsetHeight;
            animation?.cancel();
            animation = content.animate(
              [{ height: `${startHeight}px` }, { height: '0px' }],
              { duration: 200, easing: 'ease' },
            );
            animation.onfinish = () => {
              details.open = false;
              content.style.height = '0px';
              details.classList.remove('is-animating');
            };
          }
        });
      }

      initDetailsAnimation();
      document.addEventListener('astro:page-load', initDetailsAnimation);
    </script>
  </body>
</html>
