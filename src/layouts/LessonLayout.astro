---
import BaseLayout from './BaseLayout.astro';
import Badge from '../components/Badge.astro';
import { withBase } from '../lib/url';
import { getLesson, SKILLS } from '../data/lessons';
import { WORDS } from '../data/words';

interface Props {
  slug: string;
  /** For pages not in the LESSONS registry (e.g. reading question-type
      pages): supply the metadata directly. */
  meta?: { title: string; description: string; skill: import('../data/lessons').Skill };
  /** Extra breadcrumb level between Home and this page. */
  parent?: { label: string; href: string };
}

const { slug, meta, parent } = Astro.props;
const lesson = meta ? { ...meta, slug, image: '' } : getLesson(slug);
if (!lesson) throw new Error(`Unknown lesson slug: ${slug}`);
const skill = SKILLS.find((s) => s.id === lesson.skill)!;
---

<BaseLayout title={`${lesson.title} · IELTS Portal`} description={lesson.description}>
  <div class={`skill-${lesson.skill}`}>
    <!-- Lesson hero band -->
    <section class="lesson-hero border-b border-border">
      <div class="lesson-hero-word">
        <button
          type="button"
          id="lesson-hero-word-text"
          class="lesson-hero-word-text"
          aria-label="Click to test yourself on this vocabulary word"
          aria-expanded="false"
          aria-controls="lesson-hero-word-panel"
          data-vocab-quiz-trigger
          data-words={JSON.stringify(WORDS.map(({ word, def }) => ({ word, def })))}
        ></button>
      </div>
      <div class="lesson-hero-content mx-auto max-w-4xl px-4 py-10 sm:px-6">
        <nav class="mb-4 flex items-center gap-1.5 text-sm text-ink-muted" aria-label="Breadcrumb">
          <a href={withBase('/')} class="hover:text-ink">Home</a>
          <span aria-hidden="true">/</span>
          {
            parent && (
              <>
                <a href={parent.href} class="hover:text-ink">{parent.label}</a>
                <span aria-hidden="true">/</span>
              </>
            )
          }
          <span class="font-medium text-ink">{lesson.title}</span>
        </nav>
        <Badge tone="skill">{skill.label}</Badge>
        <h1 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">{lesson.title}</h1>
        <p class="mt-3 max-w-2xl text-ink-muted">{lesson.description}</p>
        <!-- The floating word drifts and can't host its own panel, so its
             quiz expands here instead, in the static content column. -->
        <div id="lesson-hero-word-panel" class="vocab-quiz-panel mt-4" hidden>
          <p class="vocab-quiz-panel-eyebrow">Quick check</p>
          <h2 class="vocab-quiz-panel-word"></h2>
          <p class="vocab-quiz-panel-prompt">Which definition is correct?</p>
          <div class="vocab-quiz-panel-opts"></div>
        </div>
      </div>
    </section>

    <!-- Migrated lesson content -->
    <article class="lesson-body mx-auto max-w-4xl px-4 py-10 sm:px-6">
      <slot />

      <div class="mt-12 flex flex-col items-center gap-4 border-t border-border pt-8">
        <button
          type="button"
          id="lesson-complete-btn"
          data-slug={slug}
          class="inline-flex items-center gap-2 rounded-button border border-border bg-surface px-6 py-2.5 font-display text-sm font-semibold transition-colors hover:border-success hover:text-success data-[done]:border-success data-[done]:bg-success-tint data-[done]:text-success"
        >
          <span data-icon>○</span>
          <span data-label>Mark lesson as complete</span>
        </button>
      </div>
    </article>
  </div>
</BaseLayout>

<style is:global>
  @import '../styles/lesson.css';
</style>

<script>
  import { initReadingQuiz } from '../scripts/lesson-quiz';
  import type { VocabWord } from '../scripts/vocab-quiz';
  import { isLessonComplete, markLessonComplete, unmarkLessonComplete } from '../lib/progress';

  initReadingQuiz();

  // Floating vocabulary word that drifts across the hero panel — one
  // word per lap, swapped to a new random word (never repeating the
  // one just shown) exactly when the CSS drift animation loops, i.e.
  // while the word is off-screen and invisible, so the swap is never
  // visible mid-flight. It's also a [data-vocab-quiz-trigger] pointing
  // (via aria-controls) at #lesson-hero-word-panel above — clicking it
  // expands that inline panel with whatever word is showing at the
  // time. The click wiring itself lives in vocab-quiz.ts (initialized
  // once site-wide by VocabQuizInit.astro), not here.
  const heroWord = document.getElementById('lesson-hero-word-text');
  if (heroWord) {
    const words: VocabWord[] = JSON.parse(heroWord.dataset.words!);
    let last = -1;
    const nextWord = () => {
      let i = Math.floor(Math.random() * words.length);
      if (words.length > 1) while (i === last) i = Math.floor(Math.random() * words.length);
      last = i;
      heroWord.textContent = words[i]!.word;
    };
    nextWord();
    heroWord.addEventListener('animationiteration', (e) => {
      if (e.animationName === 'lesson-hero-word-drift') nextWord();
    });
  }

  const btn = document.getElementById('lesson-complete-btn');
  if (btn) {
    const slug = btn.dataset.slug!;
    const render = (done: boolean) => {
      btn.toggleAttribute('data-done', done);
      btn.querySelector('[data-icon]')!.textContent = done ? '✓' : '○';
      btn.querySelector('[data-label]')!.textContent = done
        ? 'Lesson completed, tap to undo'
        : 'Mark lesson as complete';
    };
    render(isLessonComplete(slug));
    btn.addEventListener('click', () => {
      const next = !isLessonComplete(slug);
      next ? markLessonComplete(slug) : unmarkLessonComplete(slug);
      render(next);
    });
  }

  // Completion checkmarks on any "<skill> lessons" grid on this page — the
  // per-skill overview (e.g. /lessons/writing) and the cross-links inside
  // "start here" method lessons both use .sample-card. Resolve via the
  // anchor's fully-qualified pathname (not the raw href) so it works
  // whether the link is written as "writing/charts" (from the overview,
  // one directory up) or just "charts" (from a sibling lesson page, same
  // directory) — both resolve to the same last two path segments.
  document.querySelectorAll<HTMLAnchorElement>('.sample-card[href]').forEach((card) => {
    const segments = card.pathname.split('/').filter(Boolean);
    const lessonSlug = segments.slice(-2).join('-');
    if (!isLessonComplete(lessonSlug)) return;
    const status = document.createElement('span');
    status.className = 'sample-status';
    status.title = 'Completed';
    status.textContent = '✓';
    card.prepend(status);
  });
</script>
