---
import LessonLayout from '../../../layouts/LessonLayout.astro';
import PracticeQuiz from '../../../components/PracticeQuiz';
import { withBase } from '../../../lib/url';
import { READING_PARTS } from '../../../data/reading';
import { READING_PRACTICE } from '../../../data/reading-practice';

export function getStaticPaths() {
  return READING_PARTS.map((part, i) => ({
    params: { part: part.slug },
    props: { part, prev: READING_PARTS[i - 1] ?? null, next: READING_PARTS[i + 1] ?? null },
  }));
}

const { part, prev, next } = Astro.props;

const fragments = import.meta.glob<string>('../../../content/lesson-bodies/reading-*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const raw = fragments[`../../../content/lesson-bodies/reading-${part.slug}.html`];
if (!raw) throw new Error(`Missing fragment for reading part: ${part.slug}`);
const body = raw.replaceAll('../pics/', withBase('/pics/'));

const overviewUrl = withBase('/lessons/reading-task1');
const practice = READING_PRACTICE[part.slug];
---

<LessonLayout
  slug={`reading-${part.slug}`}
  meta={{ title: part.title, description: part.blurb, skill: 'reading' }}
  parent={{ label: 'Reading', href: overviewUrl }}
>
  <Fragment set:html={body} />

  {practice && <PracticeQuiz client:load set={practice} />}

  <nav class="mt-12 grid gap-3 border-t border-border pt-6 sm:grid-cols-3" aria-label="Reading section">
    {
      prev ? (
        <a href={withBase(`/lessons/reading/${prev.slug}`)} class="group rounded-card border border-border p-4 transition-colors hover:border-[var(--skill)]">
          <span class="text-xs font-semibold uppercase tracking-wide text-ink-muted">← Previous</span>
          <span class="mt-1 block font-display text-sm font-bold group-hover:text-[var(--skill)]">{prev.title}</span>
        </a>
      ) : (
        <span />
      )
    }
    <a href={overviewUrl} class="group rounded-card border border-border p-4 text-center transition-colors hover:border-[var(--skill)]">
      <span class="text-xs font-semibold uppercase tracking-wide text-ink-muted">Reading</span>
      <span class="mt-1 block font-display text-sm font-bold group-hover:text-[var(--skill)]">All Question Types</span>
    </a>
    {
      next ? (
        <a href={withBase(`/lessons/reading/${next.slug}`)} class="group rounded-card border border-border p-4 text-right transition-colors hover:border-[var(--skill)]">
          <span class="text-xs font-semibold uppercase tracking-wide text-ink-muted">Next →</span>
          <span class="mt-1 block font-display text-sm font-bold group-hover:text-[var(--skill)]">{next.title}</span>
        </a>
      ) : (
        <span />
      )
    }
  </nav>
</LessonLayout>
