---
import LessonLayout from '../../layouts/LessonLayout.astro';
import EssayCheckerCta from '../../components/EssayCheckerCta.astro';
import { withBase } from '../../lib/url';
import { getWritingPart, WRITING_PARTS } from '../../data/writing';
import raw from '../../content/lesson-bodies/writing-task2.html?raw';

const body = raw.replaceAll('../pics/', withBase('/pics/'));
const part = getWritingPart('writing-task2')!;
const prev = WRITING_PARTS[0];
const overviewUrl = withBase('/lessons/writing');
---

<LessonLayout
  slug="writing-task2"
  meta={{ title: 'Writing Task 2', description: part.blurb, skill: 'writing' }}
  parent={{ label: 'Writing', href: overviewUrl }}
>
  <Fragment set:html={body} />
  <EssayCheckerCta task="task2" />

  <nav class="mt-12 grid gap-3 border-t border-border pt-6 sm:grid-cols-3" aria-label="Writing section">
    <a href={withBase(`/lessons/${prev.slug}`)} class="group rounded-card border border-border p-4 transition-colors hover:border-[var(--skill)]">
      <span class="text-xs font-semibold uppercase tracking-wide text-ink-muted">← Previous</span>
      <span class="mt-1 block font-display text-sm font-bold group-hover:text-[var(--skill)]">{prev.title}</span>
    </a>
    <a href={overviewUrl} class="group rounded-card border border-border p-4 text-center transition-colors hover:border-[var(--skill)]">
      <span class="text-xs font-semibold uppercase tracking-wide text-ink-muted">Writing</span>
      <span class="mt-1 block font-display text-sm font-bold group-hover:text-[var(--skill)]">Overview & Both Tasks</span>
    </a>
    <span></span>
  </nav>
</LessonLayout>
