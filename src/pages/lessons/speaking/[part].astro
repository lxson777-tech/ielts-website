---
import LessonLayout from '../../../layouts/LessonLayout.astro';
import { withBase } from '../../../lib/url';
import { SPEAKING_PARTS } from '../../../data/speaking';

export function getStaticPaths() {
  return SPEAKING_PARTS.map((part, i) => ({
    params: { part: part.slug },
    props: { part, prev: SPEAKING_PARTS[i - 1] ?? null, next: SPEAKING_PARTS[i + 1] ?? null },
  }));
}

const { part, prev, next } = Astro.props;

const fragments = import.meta.glob<string>('../../../content/lesson-bodies/speaking-*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const raw = fragments[`../../../content/lesson-bodies/speaking-${part.slug}.html`];
if (!raw) throw new Error(`Missing fragment for speaking part: ${part.slug}`);
const body = raw.replaceAll('../pics/', withBase('/pics/'));

const overviewUrl = withBase('/lessons/speaking');
---

<LessonLayout
  slug={`speaking-${part.slug}`}
  meta={{ title: part.title, description: part.blurb, skill: 'speaking' }}
  parent={{ label: 'Speaking', href: overviewUrl }}
>
  <Fragment set:html={body} />

  <nav class="mt-12 grid gap-3 border-t border-border pt-6 sm:grid-cols-3" aria-label="Speaking section">
    {
      prev ? (
        <a href={withBase(`/lessons/speaking/${prev.slug}`)} class="group rounded-card border border-border p-4 transition-colors hover:border-[var(--skill)]">
          <span class="text-xs font-semibold uppercase tracking-wide text-ink-muted">← Previous</span>
          <span class="mt-1 block font-display text-sm font-bold group-hover:text-[var(--skill)]">{prev.title}</span>
        </a>
      ) : (
        <span />
      )
    }
    <a href={overviewUrl} class="group rounded-card border border-border p-4 text-center transition-colors hover:border-[var(--skill)]">
      <span class="text-xs font-semibold uppercase tracking-wide text-ink-muted">Speaking</span>
      <span class="mt-1 block font-display text-sm font-bold group-hover:text-[var(--skill)]">All Three Parts</span>
    </a>
    {
      next ? (
        <a href={withBase(`/lessons/speaking/${next.slug}`)} class="group rounded-card border border-border p-4 text-right transition-colors hover:border-[var(--skill)]">
          <span class="text-xs font-semibold uppercase tracking-wide text-ink-muted">Next →</span>
          <span class="mt-1 block font-display text-sm font-bold group-hover:text-[var(--skill)]">{next.title}</span>
        </a>
      ) : (
        <span />
      )
    }
  </nav>
</LessonLayout>
