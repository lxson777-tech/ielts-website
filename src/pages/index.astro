---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import SectionHeading from '../components/SectionHeading.astro';
import WordOfTheDay from '../components/WordOfTheDay.astro';
import { withBase } from '../lib/url';
import { LESSONS, SKILLS } from '../data/lessons';
---

<BaseLayout title="IELTS Portal · Free IELTS Preparation">
  <!-- Hero -->
  <section class="aurora-hero border-b border-border">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-4 py-16 sm:px-6 md:grid-cols-2 md:py-20">
      <div>
        <p class="mb-4 inline-block rounded-full bg-brand-tint px-3 py-1 text-xs font-bold uppercase tracking-wider text-brand">
          Free · No sign-up needed
        </p>
        <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl">
          Master IELTS,<br />one skill at a time.
        </h1>
        <p class="mt-4 max-w-md text-lg text-ink-muted">
          Clear lessons for every paper, real exam question types, and timed practice tests that estimate your band score.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={withBase('/start')} variant="gradient" size="lg">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
              <circle cx="12" cy="12" r="10" />
              <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76" />
            </svg>
            New here? Build my study plan →
          </Button>
          <Button href="#skills" variant="secondary" size="lg">Browse lessons</Button>
          <Button href={withBase('/tests')} variant="secondary" size="lg">Take a practice test</Button>
        </div>
      </div>
      <div class="hidden justify-center md:flex">
        <img
          src={withBase('/pics/hero.png')}
          alt="Student preparing for IELTS"
          class="max-h-80 w-auto rounded-card border border-border bg-white shadow-card"
        />
      </div>
    </div>
  </section>

  <!-- Progress strip (hidden until localStorage has data — populated in Phase 5) -->
  <section id="progress-strip" class="hidden border-b border-border bg-surface">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center gap-x-8 gap-y-2 px-4 py-4 text-sm sm:px-6">
      <p class="font-semibold">Your progress</p>
      <p class="text-ink-muted"><span id="progress-lessons" class="font-semibold text-ink">0</span> lessons completed</p>
      <p class="text-ink-muted">Best reading band: <span id="progress-band" class="font-semibold text-brand">-</span></p>
      <p id="progress-writing-band" class="hidden text-ink-muted">Best writing band: <span id="progress-writing-band-value" class="font-semibold text-brand">-</span></p>
      <p id="progress-speaking-band" class="hidden text-ink-muted">Best speaking band: <span id="progress-speaking-band-value" class="font-semibold text-brand">-</span></p>
      <a href={withBase('/account')} class="ml-auto font-semibold text-brand hover:text-brand-hover">View my progress →</a>
    </div>
  </section>

  <!-- Word of the day -->
  <section class="mx-auto max-w-6xl px-4 pt-12 sm:px-6">
    <WordOfTheDay />
  </section>

  <!-- Skill sections -->
  <div id="skills" class="mx-auto max-w-6xl space-y-16 px-4 py-16 sm:px-6">
    {
      SKILLS.map((skill) => {
        const lessons = LESSONS.filter((l) => l.skill === skill.id);
        if (lessons.length === 0) return null;
        return (
          <section class={`skill-${skill.id}`} id={skill.id} aria-labelledby={`heading-${skill.id}`}>
            <SectionHeading eyebrow={skill.label} title={skill.label} subtitle={skill.blurb} id={`heading-${skill.id}`} />
            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
              {lessons.map((lesson) => (
                <Card
                  title={lesson.title}
                  href={withBase(`/lessons/${lesson.slug}`)}
                  description={lesson.description}
                  image={lesson.image}
                  badge={skill.label}
                  level={lesson.level}
                  dataKey={lesson.slug}
                />
              ))}
              {skill.id === 'reading' && (
                <Card
                  title="Timed Practice Tests"
                  href={withBase('/tests')}
                  description="Full reading passages with a real 60-minute timer and band estimate."
                  image="/pics/reading/timed-test.png"
                  badge="Practice"
                />
              )}
              {skill.id === 'reading' && (
                <Card
                  title="Reading Trainer"
                  href={withBase('/trainers/reading')}
                  description="Short on time? One passage at a time with live strategy coaching, no full 60-minute commitment."
                  image="/pics/reading/timed-test.png"
                  badge="Trainer"
                  level="Beginner"
                />
              )}
              {skill.id === 'writing' && (
                <Card
                  title="Writing Checker"
                  href={withBase('/tests')}
                  description="Write an answer and get AI examiner feedback: a band for every criterion, corrections, and next-band tips."
                  image="/pics/writing/essay-checker.png"
                  badge="Practice"
                />
              )}
              {skill.id === 'speaking' && (
                <Card
                  title="Live AI Examiner"
                  href={withBase('/speaking/examiner')}
                  description="A real voice conversation with an AI examiner, all three parts, with follow-up questions based on what you say."
                  image="/pics/speaking/live-examiner.png"
                  badge="Practice"
                />
              )}
            </div>
          </section>
        );
      })
    }
  </div>
</BaseLayout>

<script>
  import {
    completedLessonCount,
    getBestBand,
    getBestWritingBand,
    getBestSpeakingBand,
    isLessonComplete,
  } from '../lib/progress';

  // Progress strip — only shown once there is something to report.
  const lessonsDone = completedLessonCount();
  const best = getBestBand();
  const bestWriting = getBestWritingBand();
  const bestSpeaking = getBestSpeakingBand();
  if (lessonsDone > 0 || best || bestWriting || bestSpeaking) {
    document.getElementById('progress-strip')?.classList.remove('hidden');
    document.getElementById('progress-lessons')!.textContent = String(lessonsDone);
    if (best) document.getElementById('progress-band')!.textContent = best.bandLabel;
    if (bestWriting) {
      document.getElementById('progress-writing-band')?.classList.remove('hidden');
      document.getElementById('progress-writing-band-value')!.textContent = bestWriting.toFixed(1);
    }
    if (bestSpeaking) {
      document.getElementById('progress-speaking-band')?.classList.remove('hidden');
      document.getElementById('progress-speaking-band-value')!.textContent = bestSpeaking.toFixed(1);
    }
  }

  // Checkmark badge on completed lesson cards.
  document.querySelectorAll<HTMLElement>('[data-key]').forEach((card) => {
    if (!isLessonComplete(card.dataset.key!)) return;
    const slot = card.querySelector('[data-slot="status"]');
    if (slot) {
      slot.innerHTML =
        '<span class="grid h-5 w-5 place-items-center rounded-full bg-success text-[10px] font-bold text-white" title="Completed">✓</span>';
    }
  });
</script>
