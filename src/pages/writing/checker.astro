---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import WritingTester from '../../components/WritingTester';
---

<BaseLayout
  title="Essay Checker · IELTS Portal"
  description="Write an IELTS essay and get instant feedback: word count, vocabulary range, cohesion, spelling, and band-by-band comments."
>
  <div class="skill-writing mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <SectionHeading
      eyebrow="Writing"
      title="Essay Checker"
      subtitle="Pick a task, write your answer, and get instant feedback on the four IELTS criteria — plus a mechanics check on length, vocabulary, cohesion and spelling."
    />
    <WritingTester client:load />
  </div>
</BaseLayout>
