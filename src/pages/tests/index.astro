---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import Badge from '../../components/Badge.astro';
import ScoreHistory from '../../components/ScoreHistory';
import TypeAnalytics from '../../components/TypeAnalytics';
import { withBase } from '../../lib/url';
import { ALL_TESTS } from '../../data/tests';
import { questionCount } from '../../lib/tests/schema';

const skillLabel = { reading: 'Reading', listening: 'Listening' } as const;
---

<BaseLayout
  title="Practice Tests · IELTS Portal"
  description="Timed IELTS practice tests with instant scoring and band estimates."
>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <SectionHeading
      eyebrow="Practice"
      title="Full Practice Tests"
      subtitle="Complete IELTS exams under real timing — once you start, the clock cannot be paused. Instant scoring, an estimated band, and results saved on this device."
    />

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        ALL_TESTS.map((test) => (
          <a
            href={withBase(`/tests/${test.id}`)}
            class={`skill-${test.skill} group relative flex flex-col overflow-hidden rounded-card border border-border bg-surface p-5 shadow-card transition-all duration-200 hover:-translate-y-1 hover:shadow-card-hover`}
            data-test-id={test.id}
          >
            <span class="absolute inset-x-0 top-0 h-1 bg-[var(--skill)]" />
            <div class="flex items-center justify-between gap-2">
              <Badge tone="skill">{skillLabel[test.skill]}</Badge>
              <span data-slot="best-band" class="text-xs font-bold text-brand" />
            </div>
            <h3 class="mt-3 font-display text-lg font-bold">{test.title}</h3>
            <p class="mt-1 text-sm text-ink-muted">{test.description}</p>
            <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 border-t border-border pt-3 text-xs font-semibold text-ink-muted">
              <span>{test.parts.length} passages</span>
              <span>{questionCount(test)} questions</span>
              <span>⏱ {test.durationMinutes} min</span>
              <span class="ml-auto font-bold text-[var(--skill)] opacity-0 transition-opacity group-hover:opacity-100">
                Start →
              </span>
            </div>
          </a>
        ))
      }
    </div>

    <section id="analytics" class="mt-16 scroll-mt-20">
      <SectionHeading
        title="Your weak spots"
        subtitle="Accuracy by question type across every attempt on this device — drill the red ones first."
      />
      <TypeAnalytics client:load />
    </section>

    <section id="history" class="mt-16 scroll-mt-20">
      <SectionHeading title="Your score history" subtitle="Attempts are stored in your browser — no account needed." />
      <ScoreHistory client:load />
    </section>
  </div>
</BaseLayout>

<script>
  import { getBestBand } from '../../lib/progress';
  document.querySelectorAll<HTMLElement>('[data-test-id]').forEach((card) => {
    const best = getBestBand(card.dataset.testId!);
    const slot = card.querySelector('[data-slot="best-band"]');
    if (best && slot) slot.textContent = `Best: Band ${best.bandLabel}`;
  });
</script>
