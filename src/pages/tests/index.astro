---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import Badge from '../../components/Badge.astro';
import ScoreHistory from '../../components/ScoreHistory';
import TypeAnalytics from '../../components/TypeAnalytics';
import { withBase } from '../../lib/url';
import { ALL_TESTS } from '../../data/tests';
import { questionCount } from '../../lib/tests/schema';
import { WRITING_PROMPTS } from '../../data/writing-prompts';
import { SPEAKING_CUE_CARDS } from '../../data/speaking-prompts';

/* One button, a different exam every attempt — the cycle covers every test
   before any repeats. Only the ids ship to the client; the test content
   itself stays on the per-test pages. */
const sample = ALL_TESTS[0];
const testIds = ALL_TESTS.map((t) => t.id);

/* Writing and Speaking are single free-form tools (not a rotating pool of
   fixed exams like Reading), so their cards link straight to the Writing
   Trainer / Live AI Examiner pages — no client-side rotation script needed
   here. */
const task1Count = WRITING_PROMPTS.filter((p) => p.task === 'task1').length;
const task2Count = WRITING_PROMPTS.filter((p) => p.task === 'task2').length;
---

<BaseLayout
  title="Practice Tests · IELTS Portal"
  description="Timed IELTS practice tests with instant scoring and band estimates."
>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <SectionHeading
      eyebrow="Practice"
      title="Take a Practice Test"
      subtitle="Press start and you'll get a full IELTS exam — a different test every time, until you've done them all. Instant scoring, an estimated band, and results saved on this device."
    />

    <div class="skill-reading relative overflow-hidden rounded-card border border-border bg-surface shadow-card">
      <span class="absolute inset-x-0 top-0 h-1 bg-[var(--skill)]"></span>
      <div class="grid items-center gap-8 p-8 sm:p-10 md:grid-cols-[1fr_minmax(0,300px)]">
        <div class="text-center md:text-left">
          <Badge tone="skill">Reading</Badge>
          <h3 class="mt-3 font-display text-2xl font-extrabold sm:text-3xl">Full Reading Test</h3>
          <p class="mt-2 text-sm text-ink-muted sm:text-[0.95rem]">
            {ALL_TESTS.length} complete exams in rotation — you won't see the same test twice until
            you've taken them all.
          </p>
          <div class="mt-5 flex flex-wrap items-center justify-center gap-x-5 gap-y-1.5 text-sm font-semibold text-ink-muted md:justify-start">
            <span>{sample.parts.length} passages</span>
            <span>{questionCount(sample)} questions</span>
            <span>⏱ {sample.durationMinutes} min</span>
          </div>
          <button
            type="button"
            id="start-test"
            data-test-ids={JSON.stringify(testIds)}
            class="mt-7 rounded-button bg-brand px-8 py-3 font-display text-lg font-bold text-white transition-colors hover:bg-brand-hover"
          >
            Start a test →
          </button>
          <p class="mt-3 text-xs text-ink-muted">Once you begin, the clock cannot be paused.</p>
          <p class="mt-4 text-sm">
            <a href={withBase('/trainers/reading')} class="font-semibold text-brand hover:underline">
              Only have 20 minutes? Try the Reading Trainer →
            </a>
          </p>
        </div>
        <img
          src={withBase('/pics/reading/start-test.png')}
          alt="Stopwatch at 60:00 beside a reading test booklet"
          class="mx-auto -order-1 w-full max-w-[240px] md:order-none md:max-w-[300px]"
          loading="lazy"
        />
      </div>
    </div>

    <div class="skill-writing relative mt-8 overflow-hidden rounded-card border border-border bg-surface shadow-card">
      <span class="absolute inset-x-0 top-0 h-1 bg-[var(--skill)]"></span>
      <div class="grid items-center gap-8 p-8 sm:p-10 md:grid-cols-[1fr_minmax(0,300px)]">
        <div class="text-center md:text-left">
          <Badge tone="skill">Writing</Badge>
          <h3 class="mt-3 font-display text-2xl font-extrabold sm:text-3xl">Writing Checker</h3>
          <p class="mt-2 text-sm text-ink-muted sm:text-[0.95rem]">
            Get instant, AI-graded feedback on Task 1 and Task 2 essays — plus a mechanics check on
            length, vocabulary, cohesion and spelling.
          </p>
          <div class="mt-5 flex flex-wrap items-center justify-center gap-x-5 gap-y-1.5 text-sm font-semibold text-ink-muted md:justify-start">
            <span>{task1Count} Task 1 prompts</span>
            <span>{task2Count} Task 2 prompts</span>
            <span>✨ Instant AI feedback</span>
          </div>
          <a
            href={withBase('/trainers/writing')}
            class="mt-7 inline-block rounded-button bg-brand px-8 py-3 font-display text-lg font-bold text-white transition-colors hover:bg-brand-hover"
          >
            Start writing →
          </a>
          <p class="mt-3 text-xs text-ink-muted">A different prompt every attempt — write at your own pace.</p>
        </div>
        <img
          src={withBase('/pics/writing/start-task.png')}
          alt="Essay draft with a band-score feedback panel beside it"
          class="mx-auto -order-1 w-full max-w-[240px] md:order-none md:max-w-[300px]"
          loading="lazy"
        />
      </div>
    </div>

    <div class="skill-speaking relative mt-8 overflow-hidden rounded-card border border-border bg-surface shadow-card">
      <span class="absolute inset-x-0 top-0 h-1 bg-[var(--skill)]"></span>
      <div class="grid items-center gap-8 p-8 sm:p-10 md:grid-cols-[1fr_minmax(0,300px)]">
        <div class="text-center md:text-left">
          <Badge tone="skill">Speaking</Badge>
          <h3 class="mt-3 font-display text-2xl font-extrabold sm:text-3xl">Live AI Examiner</h3>
          <p class="mt-2 text-sm text-ink-muted sm:text-[0.95rem]">
            A full three-part mock speaking test as a real voice conversation — the examiner speaks,
            listens, and asks follow-up questions based on what you actually say.
          </p>
          <div class="mt-5 flex flex-wrap items-center justify-center gap-x-5 gap-y-1.5 text-sm font-semibold text-ink-muted md:justify-start">
            <span>3 parts</span>
            <span>{SPEAKING_CUE_CARDS.length} cue cards</span>
            <span>🎙 Real-time voice</span>
          </div>
          <a
            href={withBase('/speaking/examiner')}
            class="mt-7 inline-block rounded-button bg-brand px-8 py-3 font-display text-lg font-bold text-white transition-colors hover:bg-brand-hover"
          >
            Start the interview →
          </a>
          <p class="mt-3 text-xs text-ink-muted">Microphone access required — the examiner listens and replies out loud.</p>
          <p class="mt-4 text-sm">
            <a href={withBase('/trainers/speaking')} class="font-semibold text-brand hover:underline">
              Want to practice one part at a time instead? →
            </a>
          </p>
        </div>
        <img
          src={withBase('/pics/speaking/start-interview.png')}
          alt="Microphone with sound waves beside three numbered speaking-test parts"
          class="mx-auto -order-1 w-full max-w-[240px] md:order-none md:max-w-[300px]"
          loading="lazy"
        />
      </div>
    </div>

    <section id="analytics" class="mt-16 scroll-mt-20">
      <SectionHeading
        title="Your weak spots"
        subtitle="Accuracy by question type across every attempt on this device — drill the red ones first."
      />
      <TypeAnalytics client:load />
    </section>

    <section id="history" class="mt-16 scroll-mt-20">
      <SectionHeading title="Your score history" subtitle="Attempts are stored in your browser — no account needed." />
      <ScoreHistory client:load />
    </section>
  </div>
</BaseLayout>

<script>
  import { withBase } from '../../lib/url';
  import { nextInRotation } from '../../lib/rotation';
  import { activeSession, secondsLeft } from '../../lib/test-session';

  const btn = document.getElementById('start-test') as HTMLButtonElement | null;
  if (btn) {
    const ids: string[] = JSON.parse(btn.dataset.testIds!);

    // An unfinished attempt means the clock is still running — send the
    // student back to it instead of handing out a new exam.
    const session = activeSession();
    const resume = session && ids.includes(session.testId) && secondsLeft(session) > 0 ? session : null;
    if (resume) {
      btn.textContent = `Resume your test — ${Math.ceil(secondsLeft(resume) / 60)} min left`;
    }

    btn.addEventListener('click', () => {
      const id = resume ? resume.testId : nextInRotation('ielts.rotation.reading-tests.v1', ids);
      window.location.href = withBase(`/tests/${id}`);
    });
  }
</script>
