---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import WritingTester from '../../components/WritingTester';
import WritingHistory from '../../components/WritingHistory';
---

<BaseLayout
  title="Writing Trainer · IELTS Portal"
  description="Write an IELTS essay with a live structure & language cheat-sheet, and get instant feedback: word count, vocabulary range, cohesion, spelling, and band-by-band comments."
>
  <div class="skill-writing mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <SectionHeading
      eyebrow="Writing"
      title="Writing Trainer"
      subtitle="Press start to get an exam-style task — a different one every time. Write your answer and get instant feedback on the four IELTS criteria, plus a mechanics check on length, vocabulary, cohesion and spelling."
    />
    <WritingTester client:load />

    <section id="history" class="mt-16 scroll-mt-20">
      <SectionHeading title="Your score history" subtitle="Attempts are stored in your browser — no account needed." />
      <WritingHistory client:load />
    </section>
  </div>
</BaseLayout>
