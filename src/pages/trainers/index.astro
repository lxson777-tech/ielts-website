---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import Badge from '../../components/Badge.astro';
import { withBase } from '../../lib/url';
import { ALL_DRILLS } from '../../lib/tests/drills';
import { SPEAKING_PART1_TOPICS, SPEAKING_CUE_CARDS } from '../../data/speaking-prompts';
import { WRITING_PROMPTS } from '../../data/writing-prompts';

const task1Count = WRITING_PROMPTS.filter((p) => p.task === 'task1').length;
const task2Count = WRITING_PROMPTS.filter((p) => p.task === 'task2').length;

const trainers = [
  {
    skill: 'reading',
    title: 'Reading Trainer',
    description:
      'One timed passage at a time, with a live "how to approach it" strategy panel and trap warnings for every question type.',
    stats: `${ALL_DRILLS.length} drills`,
    href: '/trainers/reading',
    cta: 'Start a drill →',
  },
  {
    skill: 'speaking',
    title: 'Speaking Trainer',
    description:
      'Practice Part 1, 2 or 3 on its own, with a structure & conjunction cheat-sheet (A.R.E. / PEEL / OREO) while you prep and answer.',
    stats: `${SPEAKING_PART1_TOPICS.length} Part 1 topics · ${SPEAKING_CUE_CARDS.length} cue cards`,
    href: '/trainers/speaking',
    cta: 'Start a part →',
  },
  {
    skill: 'writing',
    title: 'Writing Trainer',
    description:
      'Write against a rotating prompt with a live structure & language cheat-sheet for that exact question type, then get instant AI feedback.',
    stats: `${task1Count} Task 1 prompts · ${task2Count} Task 2 prompts`,
    href: '/trainers/writing',
    cta: 'Start writing →',
  },
];
---

<BaseLayout
  title="Trainers · IELTS Portal"
  description="Focused, single-skill practice drills with live strategy coaching — a lighter alternative to a full timed exam."
>
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
    <SectionHeading
      eyebrow="Trainers"
      title="Practice Trainers"
      subtitle="Shorter, focused drills that coach you while you practice — a strategy panel for Reading, a structure cheat-sheet for Speaking and Writing. Want the full timed exam experience instead? Head to Practice Tests."
    />

    <div class="grid gap-6 sm:grid-cols-3">
      {trainers.map((t) => (
        <div class={`skill-${t.skill} relative overflow-hidden rounded-card border border-border bg-surface p-6 shadow-card`}>
          <span class="absolute inset-x-0 top-0 h-1 bg-[var(--skill)]" aria-hidden="true"></span>
          <Badge tone="skill">{t.title.replace(' Trainer', '')}</Badge>
          <h3 class="mt-3 font-display text-xl font-extrabold">{t.title}</h3>
          <p class="mt-2 text-sm text-ink-muted">{t.description}</p>
          <p class="mt-4 text-xs font-semibold text-ink-muted">{t.stats}</p>
          <a
            href={withBase(t.href)}
            class="mt-5 inline-block rounded-button bg-brand px-5 py-2.5 text-sm font-bold text-white transition-colors hover:bg-brand-hover"
          >
            {t.cta}
          </a>
        </div>
      ))}
    </div>

    <p class="mt-8 text-center text-sm">
      <a href={withBase('/tests')} class="font-semibold text-brand hover:underline">
        Looking for a full timed exam instead? →
      </a>
    </p>
  </div>
</BaseLayout>
