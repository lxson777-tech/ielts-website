---
interface Props {
  summary?: string;
}
const { summary = 'Show model answer' } = Astro.props;
---

<details class="group my-4 rounded-card border border-border bg-surface-alt">
  <summary class="flex cursor-pointer select-none items-center gap-2 rounded-card px-5 py-3.5 font-display text-sm font-semibold text-brand transition-colors hover:bg-brand-tint">
    <svg
      class="h-4 w-4 shrink-0 transition-transform duration-200 group-open:rotate-90"
      viewBox="0 0 16 16"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M6 4l4 4-4 4"></path>
    </svg>
    {summary}
  </summary>
  <div class="border-t border-border px-5 py-4 text-[0.95rem] leading-relaxed">
    <slot />
  </div>
</details>
