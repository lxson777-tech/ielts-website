---
import { WORDS } from '../data/words';
---

<aside
  id="wotd"
  class="rounded-card border border-border bg-gradient-to-br from-brand-tint to-surface p-6 shadow-card sm:p-8"
  data-words={JSON.stringify(WORDS)}
>
  <div class="flex items-center justify-between gap-4">
    <p class="text-xs font-bold uppercase tracking-wider text-brand">Word of the day</p>
    <span id="wotd-topic" class="rounded-full bg-surface px-2.5 py-0.5 text-xs font-semibold text-ink-muted shadow-card"></span>
  </div>
  <p id="wotd-word" class="mt-3 font-display text-2xl font-extrabold sm:text-3xl"></p>
  <p id="wotd-def" class="mt-2 text-ink-muted"></p>
  <p id="wotd-example" class="mt-3 border-l-2 border-brand/40 pl-3 text-sm italic text-ink-muted"></p>
</aside>

<script>
  const el = document.getElementById('wotd')!;
  const words = JSON.parse(el.dataset.words!) as { word: string; def: string; example: string; topic: string }[];
  // Deterministic per day so every visit on the same day shows the same word.
  const daysSinceEpoch = Math.floor(Date.now() / 86_400_000);
  const w = words[daysSinceEpoch % words.length]!;
  document.getElementById('wotd-topic')!.textContent = w.topic;
  document.getElementById('wotd-word')!.textContent = w.word;
  document.getElementById('wotd-def')!.textContent = w.def;
  document.getElementById('wotd-example')!.textContent = `“${w.example}”`;
</script>
