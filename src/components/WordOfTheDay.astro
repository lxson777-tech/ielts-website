---
import { WORDS } from '../data/words';
---

<!-- Vocabulary Spotlight: a compact flashcard. Word shows first; tapping it
     reveals the definition + example with a smooth height animation (a real
     recall moment instead of just reading text), then "Next word" swaps in a
     fresh one. Narrower and more self-contained than the old full-width banner. -->
<aside
  id="wotd"
  class="skill-vocabulary mx-auto max-w-md overflow-hidden rounded-3xl border border-[var(--skill)]/15 bg-linear-to-br from-[var(--skill-tint)] via-surface to-surface shadow-card transition-shadow duration-300 hover:shadow-card-hover"
  data-words={JSON.stringify(WORDS)}
>
  <div class="p-5 sm:p-6">
    <div class="flex items-center justify-between gap-3">
      <p class="flex items-center gap-1.5 text-[0.7rem] font-bold uppercase tracking-wider text-[var(--skill)]">
        <svg viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5" aria-hidden="true">
          <path d="M10 2a6 6 0 00-3.5 10.9V15a1 1 0 001 1h5a1 1 0 001-1v-2.1A6 6 0 0010 2zM8.5 17.5a.75.75 0 000 1.5h3a.75.75 0 000-1.5h-3z" />
        </svg>
        Vocabulary Spotlight
      </p>
      <span id="wotd-topic" class="wotd-fade rounded-full bg-surface px-2.5 py-0.5 text-[0.7rem] font-semibold text-ink-muted shadow-card"></span>
    </div>

    <button
      type="button"
      id="wotd-word-btn"
      class="group mt-3 flex w-full items-center justify-between gap-2 text-left"
      aria-expanded="false"
    >
      <span id="wotd-word" class="wotd-fade font-display text-xl font-extrabold sm:text-2xl"></span>
      <span
        id="wotd-chevron"
        class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-surface text-[var(--skill)] shadow-card transition-transform duration-300 group-hover:scale-110"
        aria-hidden="true"
      >
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5">
          <path d="M5 7.5l5 5 5-5" />
        </svg>
      </span>
    </button>
    <p id="wotd-hint" class="wotd-fade mt-0.5 text-xs text-ink-muted">Tap the word to reveal its meaning</p>

    <div id="wotd-reveal" class="grid-reveal">
      <div class="min-h-0 overflow-hidden">
        <p id="wotd-def" class="mt-3 text-sm text-ink-muted"></p>
        <p id="wotd-example" class="mt-2.5 border-l-2 border-[var(--skill)]/50 pl-3 text-sm italic text-ink-muted"></p>
      </div>
    </div>
  </div>

  <button
    type="button"
    id="wotd-next"
    class="hidden w-full items-center justify-center gap-1.5 border-t border-[var(--skill)]/15 bg-surface/60 py-2.5 text-sm font-semibold text-[var(--skill)] transition-colors hover:bg-[var(--skill-tint)]"
  >
    Next word
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5" aria-hidden="true">
      <path d="M4 10h12M11 5l5 5-5 5" />
    </svg>
  </button>
</aside>

<script>
  // Module scripts only execute once, on the initial hard load — they don't
  // re-run after a client-side (astro:transitions) navigation. Without this,
  // landing back on the homepage via a soft nav re-renders a fresh (empty)
  // #wotd card that this script never touches: no word gets filled in and no
  // click listener ever gets attached, so the card looks stuck/empty and
  // unclickable. Wiring everything up only inside this listener (not also
  // directly) covers both the first load and every subsequent page swap,
  // since it fires on both.
  document.addEventListener('astro:page-load', () => {
    const el = document.getElementById('wotd');
    if (!el) return; // not on this page
    const words = JSON.parse(el.dataset.words!) as { word: string; def: string; example: string; topic: string }[];
    let last = -1;
    let revealed = false;

    const wordBtn = document.getElementById('wotd-word-btn')!;
    const chevron = document.getElementById('wotd-chevron')!;
    const reveal = document.getElementById('wotd-reveal')!;
    const hint = document.getElementById('wotd-hint')!;
    const nextBtn = document.getElementById('wotd-next')!;

    function setRevealed(open: boolean) {
      revealed = open;
      reveal.classList.toggle('is-open', open);
      wordBtn.setAttribute('aria-expanded', String(open));
      chevron.style.transform = open ? 'rotate(180deg)' : '';
      hint.textContent = open ? '' : 'Tap the word to reveal its meaning';
      nextBtn.classList.toggle('hidden', !open);
      nextBtn.classList.toggle('flex', open);
    }

    function show() {
      // Random each time, never repeating the word currently shown.
      let i = Math.floor(Math.random() * words.length);
      if (words.length > 1) while (i === last) i = Math.floor(Math.random() * words.length);
      last = i;
      const w = words[i]!;
      document.getElementById('wotd-topic')!.textContent = w.topic;
      document.getElementById('wotd-word')!.textContent = w.word;
      document.getElementById('wotd-def')!.textContent = w.def;
      document.getElementById('wotd-example')!.textContent = `“${w.example}”`;
      setRevealed(false);
    }

    show(); // fresh word on every page load

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    wordBtn.addEventListener('click', () => setRevealed(!revealed));

    nextBtn.addEventListener('click', () => {
      const fadeEls = document.querySelectorAll('.wotd-fade');
      if (reduceMotion) {
        show();
        return;
      }
      fadeEls.forEach((n) => n.classList.add('wotd-fade-out'));
      window.setTimeout(() => {
        show();
        fadeEls.forEach((n) => n.classList.remove('wotd-fade-out'));
      }, 150);
    });
  });
</script>
