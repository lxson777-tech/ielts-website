---
/**
 * Renders once, site-wide (from BaseLayout). No markup of its own —
 * just wires up every [data-vocab-quiz-trigger] already on the page
 * (e.g. the floating hero word in LessonLayout.astro) so each one can
 * expand its own inline quiz panel.
 */
---

<script>
  import { initVocabQuizTriggers } from '../scripts/vocab-quiz';
  import { WORDS } from '../data/words';

  // Module scripts only execute once, on the initial hard load — they don't
  // re-run after a client-side (astro:transitions) navigation. Wiring up
  // triggers only inside this listener (not also directly) covers both the
  // first load and every subsequent page swap, since it fires on both.
  document.addEventListener('astro:page-load', () => initVocabQuizTriggers(WORDS));
</script>
