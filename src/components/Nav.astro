---
import { withBase } from '../lib/url';
import { LESSONS, SKILLS } from '../data/lessons';

const current = Astro.url.pathname;
const isActive = (path: string) => {
  const target = withBase(path);
  return path === '/' ? current === target || current === target + '/' : current.startsWith(target);
};
---

<header class="sticky top-0 z-40 border-b border-border bg-surface/90 backdrop-blur">
  <nav class="mx-auto flex h-16 max-w-6xl items-center gap-2 px-4 sm:px-6" aria-label="Main">
    <a href={withBase('/')} class="mr-4 flex items-center gap-2 font-display text-lg font-extrabold tracking-tight">
      <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand font-display text-sm font-extrabold text-white">IE</span>
      IELTS<span class="text-brand">Portal</span>
    </a>

    <div class="ml-auto hidden items-center gap-1 md:flex">
      <a
        href={withBase('/')}
        class:list={[
          'rounded-full px-4 py-2 text-sm font-medium transition-colors',
          isActive('/') && !isActive('/lessons') && !isActive('/tests')
            ? 'bg-brand-tint text-brand'
            : 'text-ink-muted hover:bg-surface-alt hover:text-ink',
        ]}>Home</a
      >

      <div class="group relative">
        <button
          type="button"
          class:list={[
            'flex items-center gap-1 rounded-full px-4 py-2 text-sm font-medium transition-colors',
            isActive('/lessons')
              ? 'bg-brand-tint text-brand'
              : 'text-ink-muted hover:bg-surface-alt hover:text-ink',
          ]}
          aria-haspopup="true"
        >
          Lessons
          <svg class="h-3.5 w-3.5 transition-transform group-focus-within:rotate-180 group-hover:rotate-180" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 6l4 4 4-4"></path>
          </svg>
        </button>
        <div
          class="invisible absolute right-0 top-full w-64 translate-y-1 rounded-2xl border border-border bg-surface p-2 opacity-0 shadow-card-hover transition-all duration-150 group-focus-within:visible group-focus-within:translate-y-2 group-focus-within:opacity-100 group-hover:visible group-hover:translate-y-2 group-hover:opacity-100"
        >
          {SKILLS.map((skill) => (
            <div class={`skill-${skill.id}`}>
              <p class="px-3 pb-1 pt-2 text-xs font-semibold uppercase tracking-wide" style="color: var(--skill)">
                {skill.label}
              </p>
              {LESSONS.filter((l) => l.skill === skill.id).map((lesson) => (
                <a
                  href={withBase(`/lessons/${lesson.slug}`)}
                  class="block rounded-lg px-3 py-1.5 text-sm text-ink-muted transition-colors hover:bg-surface-alt hover:text-ink"
                >
                  {lesson.title}
                </a>
              ))}
            </div>
          ))}
        </div>
      </div>

      <a
        href={withBase('/tests')}
        class:list={[
          'rounded-full px-4 py-2 text-sm font-medium transition-colors',
          isActive('/tests') ? 'bg-brand-tint text-brand' : 'text-ink-muted hover:bg-surface-alt hover:text-ink',
        ]}>Practice Tests</a
      >
    </div>

    <button
      type="button"
      id="nav-toggle"
      class="ml-auto grid h-10 w-10 place-items-center rounded-lg text-ink-muted hover:bg-surface-alt md:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M3 5h14M3 10h14M3 15h14"></path>
      </svg>
    </button>
  </nav>

  <div id="nav-mobile" class="hidden border-t border-border bg-surface px-4 pb-4 md:hidden">
    <a href={withBase('/')} class="block rounded-lg px-3 py-2.5 text-sm font-medium text-ink hover:bg-surface-alt">Home</a>
    <a href={withBase('/tests')} class="block rounded-lg px-3 py-2.5 text-sm font-medium text-ink hover:bg-surface-alt">Practice Tests</a>
    <p class="px-3 pb-1 pt-3 text-xs font-semibold uppercase tracking-wide text-ink-muted">Lessons</p>
    {LESSONS.map((lesson) => (
      <a href={withBase(`/lessons/${lesson.slug}`)} class="block rounded-lg px-3 py-2 text-sm text-ink-muted hover:bg-surface-alt hover:text-ink">
        {lesson.title}
      </a>
    ))}
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
