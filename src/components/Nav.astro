---
import { withBase } from '../lib/url';
import { LESSONS, SKILLS, lessonsBySkill } from '../data/lessons';
import { READING_PARTS } from '../data/reading';
import { WRITING_PARTS } from '../data/writing';
import { SPEAKING_PARTS } from '../data/speaking';
import { LISTENING_PARTS } from '../data/listening';

const current = Astro.url.pathname;
const isPath = (path: string) => current === withBase(path) || current === withBase(path) + '.html';
const skillActive = (skillId: string) =>
  lessonsBySkill(skillId as (typeof SKILLS)[number]['id']).some((l) => isPath(`/lessons/${l.slug}`));
const testsActive = current.startsWith(withBase('/tests'));

/* Short labels for dropdown entries — the parts of each section. */
const partLabel: Record<string, string> = {
  'reading-task1': 'Reading Overview',
  writing: 'Writing Overview',
  speaking: 'Speaking Overview',
  listening: 'Listening Overview',
  vocabulary: 'Topic Vocabulary',
};
---

<header class="sticky top-0 z-40 border-b border-border bg-surface/90 backdrop-blur">
  <nav class="mx-auto flex h-16 max-w-6xl items-center px-4 sm:px-6" aria-label="Main">
    <a href={withBase('/')} class="mr-2 flex shrink-0 items-center gap-2 font-display text-lg font-extrabold tracking-tight lg:mr-6">
      <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand font-display text-sm font-extrabold text-white">IE</span>
      <span class="hidden sm:inline">IELTS<span class="text-brand">Portal</span></span>
    </a>

    <div class="ml-auto hidden items-center gap-0.5 md:flex">
      {
        SKILLS.map((skill, i) => {
          const lessons = lessonsBySkill(skill.id);
          const active = skillActive(skill.id);
          // Right-align the last two panels so they never overflow the viewport.
          const alignRight = i >= SKILLS.length - 2;
          return (
            <div class={`group relative skill-${skill.id}`}>
              <button
                type="button"
                class:list={[
                  'flex items-center gap-1.5 rounded-full px-3 py-2 font-display text-[0.95rem] font-bold tracking-tight transition-colors',
                  active
                    ? 'bg-[var(--skill-tint)] text-[var(--skill)]'
                    : 'text-ink-muted hover:bg-[var(--skill-tint)] hover:text-[var(--skill)] group-focus-within:bg-[var(--skill-tint)] group-focus-within:text-[var(--skill)]',
                ]}
                aria-haspopup="true"
                aria-expanded="false"
              >
                <span class="h-2 w-2 rounded-full bg-[var(--skill)]" aria-hidden="true"></span>
                {skill.label}
              </button>
              <div
                class:list={[
                  alignRight ? 'right-0' : 'left-0',
                  'invisible absolute top-full w-80 translate-y-1 rounded-2xl border border-border bg-surface p-3 opacity-0 shadow-card-hover transition-all duration-150',
                  'group-focus-within:visible group-focus-within:translate-y-2 group-focus-within:opacity-100',
                  'group-hover:visible group-hover:translate-y-2 group-hover:opacity-100',
                ]}
              >
                <div>
                  {lessons.map((lesson) => (
                    <a
                      href={withBase(`/lessons/${lesson.slug}`)}
                      class="flex items-center gap-3 rounded-xl px-4 py-3 text-[0.95rem] text-ink transition-colors hover:bg-[var(--skill-tint)]"
                    >
                      <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--skill)]" aria-hidden="true" />
                      {partLabel[lesson.slug] ?? lesson.title}
                    </a>
                  ))}
                  {skill.id === 'reading' &&
                    READING_PARTS.map((p) => (
                      <a
                        href={withBase(`/lessons/reading/${p.slug}`)}
                        class="flex items-center gap-3 rounded-xl px-4 py-2 pl-7 text-sm text-ink-muted transition-colors hover:bg-[var(--skill-tint)] hover:text-ink"
                      >
                        {p.title}
                      </a>
                    ))}
                  {skill.id === 'reading' && (
                    <a
                      href={withBase('/tests')}
                      class="mt-1 flex items-center gap-3 rounded-xl border-t border-border px-4 pb-3 pt-3.5 text-[0.95rem] font-semibold text-brand transition-colors hover:bg-brand-tint"
                    >
                      ⏱ Timed Practice Tests
                    </a>
                  )}
                  {skill.id === 'writing' &&
                    WRITING_PARTS.map((p) => (
                      <a
                        href={withBase(`/lessons/writing/${p.slug}`)}
                        class="flex items-center gap-3 rounded-xl px-4 py-2 pl-7 text-sm text-ink-muted transition-colors hover:bg-[var(--skill-tint)] hover:text-ink"
                      >
                        {p.title}
                      </a>
                    ))}
                  {skill.id === 'speaking' &&
                    SPEAKING_PARTS.map((p) => (
                      <a
                        href={withBase(`/lessons/speaking/${p.slug}`)}
                        class="flex items-center gap-3 rounded-xl px-4 py-2 pl-7 text-sm text-ink-muted transition-colors hover:bg-[var(--skill-tint)] hover:text-ink"
                      >
                        {p.title}
                      </a>
                    ))}
                  {skill.id === 'listening' &&
                    LISTENING_PARTS.map((p) => (
                      <a
                        href={withBase(`/lessons/listening/${p.slug}`)}
                        class="flex items-center gap-3 rounded-xl px-4 py-2 pl-7 text-sm text-ink-muted transition-colors hover:bg-[var(--skill-tint)] hover:text-ink"
                      >
                        {p.title}
                      </a>
                    ))}
                  {skill.id === 'writing' && (
                    <a
                      href={withBase('/writing/checker')}
                      class="mt-1 flex items-center gap-3 rounded-xl border-t border-border px-4 pb-3 pt-3.5 text-[0.95rem] font-semibold text-brand transition-colors hover:bg-brand-tint"
                    >
                      ✨ Essay Checker
                    </a>
                  )}
                  <a
                    href={withBase(`/#${skill.id}`)}
                    class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm text-ink-muted transition-colors hover:bg-surface-alt hover:text-ink"
                  >
                    All {skill.label.toLowerCase()} on the homepage →
                  </a>
                </div>
              </div>
            </div>
          );
        })
      }

      <a
        href={withBase('/tests')}
        class:list={[
          'ml-1 rounded-full px-3.5 py-2 text-sm font-semibold transition-colors',
          testsActive ? 'bg-brand-tint text-brand' : 'bg-brand text-white hover:bg-brand-hover',
        ]}>Tests</a
      >
    </div>

    <button
      type="button"
      id="nav-toggle"
      class="ml-auto grid h-10 w-10 place-items-center rounded-lg text-ink-muted hover:bg-surface-alt md:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M3 5h14M3 10h14M3 15h14"></path>
      </svg>
    </button>
  </nav>

  <div id="nav-mobile" class="hidden max-h-[75dvh] overflow-y-auto border-t border-border bg-surface px-4 pb-5 md:hidden">
    <a href={withBase('/')} class="block rounded-lg px-3 py-2.5 text-sm font-semibold text-ink hover:bg-surface-alt">Home</a>
    <a href={withBase('/tests')} class="block rounded-lg px-3 py-2.5 text-sm font-semibold text-brand hover:bg-brand-tint">
      Practice Tests
    </a>
    {
      SKILLS.map((skill) => (
        <div class={`skill-${skill.id} mt-2`}>
          <p class="px-3 pb-1 pt-2 text-xs font-bold uppercase tracking-wider" style="color: var(--skill)">
            {skill.label}
          </p>
          {lessonsBySkill(skill.id).map((lesson) => (
            <a
              href={withBase(`/lessons/${lesson.slug}`)}
              class="block rounded-lg px-3 py-2 pl-6 text-sm text-ink-muted hover:bg-surface-alt hover:text-ink"
            >
              {partLabel[lesson.slug] ?? lesson.title}
            </a>
          ))}
          {skill.id === 'reading' &&
            READING_PARTS.map((p) => (
              <a
                href={withBase(`/lessons/reading/${p.slug}`)}
                class="block rounded-lg px-3 py-2 pl-9 text-sm text-ink-muted hover:bg-surface-alt hover:text-ink"
              >
                {p.title}
              </a>
            ))}
          {skill.id === 'writing' &&
            WRITING_PARTS.map((p) => (
              <a
                href={withBase(`/lessons/writing/${p.slug}`)}
                class="block rounded-lg px-3 py-2 pl-9 text-sm text-ink-muted hover:bg-surface-alt hover:text-ink"
              >
                {p.title}
              </a>
            ))}
          {skill.id === 'speaking' &&
            SPEAKING_PARTS.map((p) => (
              <a
                href={withBase(`/lessons/speaking/${p.slug}`)}
                class="block rounded-lg px-3 py-2 pl-9 text-sm text-ink-muted hover:bg-surface-alt hover:text-ink"
              >
                {p.title}
              </a>
            ))}
          {skill.id === 'listening' &&
            LISTENING_PARTS.map((p) => (
              <a
                href={withBase(`/lessons/listening/${p.slug}`)}
                class="block rounded-lg px-3 py-2 pl-9 text-sm text-ink-muted hover:bg-surface-alt hover:text-ink"
              >
                {p.title}
              </a>
            ))}
          {skill.id === 'writing' && (
            <a
              href={withBase('/writing/checker')}
              class="block rounded-lg px-3 py-2 pl-6 text-sm font-semibold text-brand hover:bg-brand-tint"
            >
              ✨ Essay Checker
            </a>
          )}
        </div>
      ))
    }
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
