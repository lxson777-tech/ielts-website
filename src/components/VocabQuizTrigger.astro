---
/**
 * A clickable pill that expands its own inline "choose the right
 * meaning" panel in place — no overlay, no modal. User-triggered only;
 * it never opens on its own. Each instance is fully self-contained
 * (its own trigger + its own panel), so any number can appear on a
 * page independently.
 */
interface Props {
  label?: string;
  /** Force a specific word; omit for a random pick each time it opens. */
  word?: string;
  class?: string;
}
const { label = 'Quick vocabulary check', word, class: extra = '' } = Astro.props;
const panelId = `vocab-quiz-panel-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="vocab-quiz-inline">
  <button
    type="button"
    data-vocab-quiz-trigger
    data-vocab-word={word}
    aria-expanded="false"
    aria-controls={panelId}
    class={`inline-flex items-center gap-2 rounded-full border border-border bg-surface px-4 py-2 text-sm font-semibold text-ink-muted transition-colors hover:border-brand hover:bg-brand-tint hover:text-brand ${extra}`}
  >
    <span aria-hidden="true">🧠</span>
    {label}
  </button>
  <div id={panelId} class="vocab-quiz-panel" hidden>
    <p class="vocab-quiz-panel-eyebrow">Quick check</p>
    <h3 class="vocab-quiz-panel-word"></h3>
    <p class="vocab-quiz-panel-prompt">Which definition is correct?</p>
    <div class="vocab-quiz-panel-opts"></div>
  </div>
</div>
