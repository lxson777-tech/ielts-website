---
interface Props {
  title: string;
  subtitle?: string;
  /** Optional small pill label above the title (colored by ambient --skill). */
  eyebrow?: string;
  id?: string;
}
const { title, subtitle, eyebrow, id } = Astro.props;
---

<div class="mb-8" id={id}>
  {eyebrow && (
    <p class="mb-2 inline-block rounded-full bg-[var(--skill-tint,var(--color-brand-tint))] px-3 py-1 text-xs font-bold uppercase tracking-wider text-[var(--skill,var(--color-brand))]">
      {eyebrow}
    </p>
  )}
  <h2 class="text-3xl font-extrabold tracking-tight">{title}</h2>
  {subtitle && <p class="mt-2 max-w-xl text-ink-muted">{subtitle}</p>}
</div>
