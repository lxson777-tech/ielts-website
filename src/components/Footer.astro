---
import { withBase } from '../lib/url';
import { LESSONS } from '../data/lessons';

const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-surface-alt">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 md:grid-cols-3">
    <div>
      <p class="flex items-center gap-2 font-display text-lg font-extrabold">
        <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand font-display text-sm font-extrabold text-white">IE</span>
        IELTS<span class="text-brand">Portal</span>
      </p>
      <p class="mt-3 max-w-xs text-sm text-ink-muted">
        Free, focused IELTS preparation, with clear lessons, real question types and timed practice tests.
      </p>
    </div>
    <div>
      <p class="text-sm font-semibold">Lessons</p>
      <ul class="mt-3 grid grid-cols-2 gap-x-4 gap-y-2 text-sm text-ink-muted">
        {LESSONS.map((lesson) => (
          <li>
            <a href={withBase(`/lessons/${lesson.slug}`)} class="hover:text-ink">{lesson.title}</a>
          </li>
        ))}
      </ul>
    </div>
    <div>
      <p class="text-sm font-semibold">Practice</p>
      <ul class="mt-3 space-y-2 text-sm text-ink-muted">
        <li><a href={withBase('/trainers')} class="hover:text-ink">Trainers</a></li>
        <li><a href={withBase('/tests')} class="hover:text-ink">Practice tests</a></li>
        <li><a href={withBase('/tests#history')} class="hover:text-ink">Your score history</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-border py-5 text-center text-xs text-ink-muted">
    © {year} Almaty English Centre. All rights reserved.
  </div>
</footer>
