{"nodes": [{"id": "_agents_skills_css_animation_creator_references_performance_performance", "label": "Animation Performance Best Practices", "file_type": "document", "source_file": ".agents/skills/css-animation-creator/references/performance.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_agents_skills_css_animation_creator_references_performance_gpu_accelerated_properties", "label": "GPU-Accelerated Properties (transform/opacity only)", "file_type": "rationale", "source_file": ".agents/skills/css-animation-creator/references/performance.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Animating transform and opacity stays on the compositor thread; animating left/top/width/height/margin triggers layout and paint, causing jank especially on low-end devices."}, {"id": "_agents_skills_css_animation_creator_references_performance_will_change", "label": "will-change (use sparingly)", "file_type": "rationale", "source_file": ".agents/skills/css-animation-creator/references/performance.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Reserved only for complex animations and reset to auto afterwards, because leaving will-change active holds GPU layers and wastes memory."}], "edges": [{"source": "_agents_skills_css_animation_creator_references_performance_performance", "target": "_agents_skills_css_animation_creator_references_performance_gpu_accelerated_properties", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/css-animation-creator/references/performance.md", "source_location": null, "weight": 1.0}, {"source": "_agents_skills_css_animation_creator_references_performance_performance", "target": "_agents_skills_css_animation_creator_references_performance_will_change", "relation": "references", "conf