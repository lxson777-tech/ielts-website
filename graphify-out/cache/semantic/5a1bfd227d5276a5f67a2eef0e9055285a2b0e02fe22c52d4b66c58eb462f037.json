{"nodes": [{"id": "src_content_lesson_bodies_writing_writing_section_overview", "label": "Writing Section Overview", "file_type": "document", "source_file": "src/content/lesson-bodies/writing.html", "source_location": "#overview", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "src_content_lesson_bodies_writing_ielts_writing_task_1", "label": "IELTS Writing Task 1", "file_type": "concept", "source_file": "src/content/lesson-bodies/writing.html", "source_location": "#task1", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "20 minutes, 150+ words; Academic = report on a visual, General Training = letter. Deliberately allocated only a third of the Writing mark, so lessons steer candidates to protect Task 2 time."}, {"id": "src_content_lesson_bodies_writing_ielts_writing_task_2", "label": "IELTS Writing Task 2", "file_type": "concept", "source_file": "src/content/lesson-bodies/writing.html", "source_location": "#task2", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "40 minutes, 250+ words, counts double vs Task 1 in the band formula (Task 1 + Task 2 x 2) / 3 - the site's advice to master the essay first follows from this weighting."}, {"id": "src_content_lesson_bodies_writing_four_marking_criteria", "label": "Four Writing Marking Criteria", "file_type": "concept", "source_file": "src/content/lesson-bodies/writing.html", "source_location": "How Examiners Mark It", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Task Achievement/Response, Coherence & Cohesion, Lexical Resource, Grammatical Range & Accuracy - weighted equally at 25% each, whole band per criterion, averaged. Used as the shared scoring frame across lessons and the Essay Checker."}, {"id": "src_content_lesson_bodies_writing_task_achievement", "label": "Task Achievement", "file_type": "concept", "source_file": "src/content/lesson-bodies/writi