{"nodes": [{"id": "src_content_lesson_bodies_writing_method_how_to_answer_task_1", "label": "How to Answer Task 1 (Universal Method) Lesson", "file_type": "document", "source_file": "src/content/lesson-bodies/writing-method.html", "source_location": "#method", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "src_content_lesson_bodies_writing_method_four_paragraph_method", "label": "Four-Paragraph Task 1 Method", "file_type": "concept", "source_file": "src/content/lesson-bodies/writing-method.html", "source_location": "The Four Paragraphs", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Introduction, Overview, Detail 1, Detail 2 - one structure for every Task 1 visual. Design intent: teach the method once in this lesson so each type lesson can focus only on what to look for in that visual, avoiding repetition across chart/process/map lessons. General Training letters are the deliberate exception with their own format."}, {"id": "src_content_lesson_bodies_writing_method_overview_paragraph", "label": "Overview Paragraph", "file_type": "concept", "source_file": "src/content/lesson-bodies/writing-method.html", "source_location": "The Four Paragraphs, row 2", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Called the most important paragraph: 2-3 key features, no numbers, starts with 'Overall,'. Without a clear overview Task Achievement is capped around Band 5, which is why every report-type lesson repeats it."}], "edges": [{"source": "src_content_lesson_bodies_writing_method_how_to_answer_task_1", "target": "src_content_lesson_bodies_writing_ielts_writing_task_1", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "src/content/lesson-bodies/writing-method.html", "source_location": "tag 'Task 1 - The Universal Method'", "weight": 1.0}, {"source": "src_content_lesson_bodies_writing_method_how_to_answer_task