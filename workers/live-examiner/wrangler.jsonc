// Cloudflare Worker config for the live AI examiner token service.
// Deploy:  npx wrangler deploy   (from this directory)
// Secret:  npx wrangler secret put GEMINI_API_KEY
{
  "name": "ielts-live-examiner",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "vars": {
    // Gemini Live model the browser will talk to.
    // Switched 2026-07-16 from "gemini-2.5-flash-native-audio-preview-12-2025"
    // (native-audio dialog) after reports of misheard words; the newer live
    // model should hear accented speech better. Swap back if the examiner's
    // voice quality or conversational feel regresses.
    "LIVE_MODEL": "gemini-3.1-flash-live-preview",
    // Comma-separated origins allowed to request session tokens.
    "ALLOWED_ORIGINS": "https://lxson777-tech.github.io,http://localhost:4321,http://127.0.0.1:4321"
  }
}
